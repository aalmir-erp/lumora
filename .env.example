# Copy to .env and fill in. Railway: set these as service variables.

# Anthropic API — leave empty to run in DEMO_MODE (rule-based fallback)
ANTHROPIC_API_KEY=

# Model & generation
CLAUDE_MODEL=claude-opus-4-7
CLAUDE_MAX_TOKENS=4096

# auto = LLM if API key set, demo otherwise. Force with on/off.
DEMO_MODE=auto

# Comma-separated CORS origins for the widget
ALLOWED_ORIGINS=https://urbanservices.ae,https://www.urbanservices.ae

# Live-agent handoff destinations
HANDOFF_WHATSAPP=+971566900255
HANDOFF_EMAIL=info@urbanservices.ae

# Railway sets PORT automatically; leave unset locally to use 8000
# PORT=8000
