# --- AI backends (set the ones you'll use) ---
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# --- Default backend / runtime (overridable per task via UI) ---
# Backends: gemini-pro | gemini-flash | gemini-cu | claude-cu
DEFAULT_BACKEND=gemini-pro
# Runtimes: railway | local | hybrid
DEFAULT_RUNTIME=hybrid

# --- Local agent auth ---
# Shared secret the local agent uses to authenticate to the Railway WebSocket.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
LOCAL_AGENT_TOKEN=

# --- Webhooks ---
# Optional: scraper POSTs status updates + screenshot URLs here.
# Use this to ping a Claude session, Slack, or your own service.
STATUS_WEBHOOK_URL=

# --- Hybrid policy ---
# Comma-separated host patterns that ALWAYS go to local agent (e.g. sites
# that need your phone-linked session or your IP).
FORCE_LOCAL_HOSTS=web.whatsapp.com,*.whatsapp.com

# --- Server ---
PORT=8000
