<?xml version="1.0" encoding="utf-8"?>
<!-- v1.24.2 — 6-tile launcher with the new Voice + SOS buttons.
     Plain ScrollView+LinearLayout (no androidx.wear dep) so the
     layout resolves cleanly. Round-screen safe via 8dp padding. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:padding="8dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SERVIA"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:gravity="center"
            android:textColor="#FCD34D"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="2dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap to act"
            android:textSize="9sp"
            android:gravity="center"
            android:textColor="#94A3B8"
            android:layout_marginBottom="6dp" />

        <!-- Row 1: Voice (flagship) + SOS Recovery -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/wear_tile_voice"
                style="@style/WearTile"
                android:background="#F59E0B"
                android:textColor="#1E293B"
                android:text="🎙\nTalk"
                android:contentDescription="Talk to Servia" />
            <TextView
                android:id="@+id/wear_tile_sos"
                style="@style/WearTile"
                android:background="#DC2626"
                android:text="🆘\nSOS"
                android:contentDescription="One-tap recovery" />
        </LinearLayout>

        <!-- Row 2: Track + Quick book -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/wear_tile_track"
                style="@style/WearTile"
                android:text="📍\nTrack"
                android:contentDescription="Track booking" />
            <TextView
                android:id="@+id/wear_tile_book"
                style="@style/WearTile"
                android:text="📋\nBook"
                android:contentDescription="Quick book" />
        </LinearLayout>

        <!-- Row 3: Quote + Chat -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/wear_tile_quote"
                style="@style/WearTile"
                android:text="💬\nQuote"
                android:contentDescription="Get a quote" />
            <TextView
                android:id="@+id/wear_tile_chat"
                style="@style/WearTile"
                android:text="🤖\nChat"
                android:contentDescription="Open chat" />
        </LinearLayout>

        <!-- v1.24.29 Row 4: Create custom SOS + My address -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/wear_tile_create_sos"
                style="@style/WearTile"
                android:background="#065F46"
                android:text="➕\nCreate SOS"
                android:contentDescription="Create custom SOS button" />
            <TextView
                android:id="@+id/wear_tile_address"
                style="@style/WearTile"
                android:background="#1E40AF"
                android:text="📍\nAddress"
                android:contentDescription="My saved address" />
        </LinearLayout>

        <!-- v1.24.29 Row 5: My SOS shortcuts -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/wear_tile_mysos"
                style="@style/WearTile"
                android:background="#6366F1"
                android:text="🎯\nMy SOS"
                android:contentDescription="Open my saved SOS shortcuts" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
