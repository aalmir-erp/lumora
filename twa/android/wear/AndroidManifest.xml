<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">
    <uses-feature android:name="android.hardware.type.watch" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Wearable Data Layer requires foreground service when listening -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Recovery one-tap (v1.24.1): real GPS + dial-vendor button -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <!-- Voice assistant (v1.24.2): mic + speak-back -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />
    <uses-feature android:name="android.hardware.location.gps" android:required="false" />

    <application
        android:label="@string/wear_app_name"
        android:icon="@mipmap/wear_ic_launcher"
        android:theme="@android:style/Theme.DeviceDefault"
        android:allowBackup="true"
        android:supportsRtl="true">

        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <activity
            android:name="ae.servia.wear.MainActivity"
            android:exported="true"
            android:label="@string/wear_app_name"
            android:theme="@android:style/Theme.DeviceDefault.Light">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name="ae.servia.wear.BookingTrackActivity"
                  android:exported="false"
                  android:label="Bookings" />
        <activity android:name="ae.servia.wear.QuickBookActivity"
                  android:exported="false"
                  android:label="Quick book" />
        <activity android:name="ae.servia.wear.QuoteActivity"
                  android:exported="false"
                  android:label="Quote" />
        <activity android:name="ae.servia.wear.ChatActivity"
                  android:exported="false"
                  android:label="Chat" />
        <!-- v1.24.2: Servia voice assistant (mic-on-launch chat) -->
        <activity android:name="ae.servia.wear.VoiceAssistantActivity"
                  android:exported="true"
                  android:label="Servia voice"
                  android:theme="@android:style/Theme.DeviceDefault.NoActionBar">
            <intent-filter>
                <action android:name="ae.servia.wear.action.VOICE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <!-- v1.24.1: One-tap vehicle-recovery dispatch -->
        <activity android:name="ae.servia.wear.RecoveryActivity"
                  android:exported="true"
                  android:label="SOS Recovery"
                  android:theme="@android:style/Theme.DeviceDefault.Light.NoActionBar">
            <intent-filter>
                <action android:name="ae.servia.wear.action.RECOVERY_SOS" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <!-- v1.24.4: First-run onboarding (phone + email) -->
        <activity android:name="ae.servia.wear.OnboardingActivity"
                  android:exported="false"
                  android:label="Welcome"
                  android:theme="@android:style/Theme.DeviceDefault.NoActionBar"
                  android:windowSoftInputMode="adjustResize" />
        <!-- v1.24.15: MySos (user's custom shortcuts) + AllServices (8-svc grid) -->
        <activity android:name="ae.servia.wear.MySosActivity"
                  android:exported="true"
                  android:label="My Servia SOS"
                  android:theme="@android:style/Theme.DeviceDefault.NoActionBar"
                  android:windowSoftInputMode="adjustResize" />
        <activity android:name="ae.servia.wear.AllServicesActivity"
                  android:exported="true"
                  android:label="All services"
                  android:theme="@android:style/Theme.DeviceDefault.NoActionBar" />

        <!-- v1.24.29: create custom SOS button on watch + per-slot dispatch + address -->
        <activity android:name="ae.servia.wear.CustomSosCreateActivity"
                  android:exported="true"
                  android:label="Create SOS"
                  android:theme="@android:style/Theme.DeviceDefault.NoActionBar"
                  android:windowSoftInputMode="adjustResize" />
        <activity android:name="ae.servia.wear.CustomSosSlotDispatchActivity"
                  android:exported="true"
                  android:label="SOS slot"
                  android:theme="@android:style/Theme.DeviceDefault.NoActionBar" />
        <activity android:name="ae.servia.wear.LocationActivity"
                  android:exported="true"
                  android:label="My address"
                  android:theme="@android:style/Theme.DeviceDefault.NoActionBar" />
        <activity android:name="ae.servia.wear.ThemePickerActivity"
                  android:exported="true"
                  android:label="Theme"
                  android:theme="@android:style/Theme.DeviceDefault.NoActionBar" />

        <!-- v1.24.33: Servia watch face (the dial itself) + companion editor.
             10 curated presets (theme x layout) + 8 customizable slots
             that can hold custom SOS shortcuts, click-to-talk, booking
             ETA, address picker, weather/battery/steps complications. -->
        <activity android:name="ae.servia.wear.watchface.WatchFaceEditorActivity"
                  android:exported="true"
                  android:label="Watch face editor"
                  android:theme="@android:style/Theme.DeviceDefault.NoActionBar">
            <intent-filter>
                <action android:name="ae.servia.wear.watchface.CONFIG" />
                <category android:name="com.google.android.wearable.watchface.category.WEARABLE_CONFIGURATION" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <service
            android:name="ae.servia.wear.watchface.ServiaWatchFaceService"
            android:label="@string/wf_face_name"
            android:permission="android.permission.BIND_WALLPAPER"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService" />
                <category android:name="com.google.android.wearable.watchface.category.WATCH_FACE" />
            </intent-filter>
            <meta-data
                android:name="com.google.android.wearable.watchface.preview"
                android:resource="@drawable/tile_preview_hub" />
            <meta-data
                android:name="com.google.android.wearable.watchface.preview_circular"
                android:resource="@drawable/tile_preview_hub" />
            <meta-data
                android:name="com.google.android.wearable.watchface.companionConfigurationAction"
                android:value="ae.servia.wear.watchface.CONFIG" />
            <meta-data
                android:name="com.google.android.wearable.watchface.wearableConfigurationAction"
                android:value="ae.servia.wear.watchface.CONFIG" />
        </service>

        <!-- v1.24.7: SOS category grid (8 tiles, matches website /sos.html).
             Launched by MainActivity SOS button + RecoveryTileService tap. -->
        <activity android:name="ae.servia.wear.SosCategoryGridActivity"
                  android:exported="true"
                  android:label="Servia SOS"
                  android:theme="@android:style/Theme.DeviceDefault.NoActionBar">
            <intent-filter>
                <action android:name="ae.servia.wear.action.SOS_GRID" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <!-- v1.24.4: Generic SOS dispatch (used by SosVehicle/Furniture/etc tiles) -->
        <activity android:name="ae.servia.wear.SosLauncherActivity"
                  android:exported="true"
                  android:label="SOS"
                  android:theme="@android:style/Theme.DeviceDefault.NoActionBar"
                  android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="ae.servia.wear.action.SOS_DISPATCH" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

