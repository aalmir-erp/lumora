<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">
    <uses-feature android:name="android.hardware.type.watch" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Wearable Data Layer requires foreground service when listening -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Recovery one-tap (v1.24.1): real GPS + dial-vendor button -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <!-- Voice assistant (v1.24.2): mic + speak-back -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />
    <uses-feature android:name="android.hardware.location.gps" android:required="false" />

    <application
        android:label="@string/wear_app_name"
        android:icon="@mipmap/wear_ic_launcher"
        android:theme="@android:style/Theme.DeviceDefault"
        android:allowBackup="true"
        android:supportsRtl="true">

        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <activity
            android:name="ae.servia.wear.MainActivity"
            android:exported="true"
            android:label="@string/wear_app_name"
            android:theme="@android:style/Theme.DeviceDefault.Light">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name="ae.servia.wear.BookingTrackActivity"
                  android:exported="false"
                  android:label="Bookings" />
        <activity android:name="ae.servia.wear.QuickBookActivity"
                  android:exported="false"
                  android:label="Quick book" />
        <activity android:name="ae.servia.wear.QuoteActivity"
                  android:exported="false"
                  android:label="Quote" />
        <activity android:name="ae.servia.wear.ChatActivity"
                  android:exported="false"
                  android:label="Chat" />
        <!-- v1.24.2: Servia voice assistant (mic-on-launch chat) -->
        <activity android:name="ae.servia.wear.VoiceAssistantActivity"
                  android:exported="true"
                  android:label="Servia voice"
                  android:theme="@android:style/Theme.DeviceDefault.NoActionBar">
            <intent-filter>
                <action android:name="ae.servia.wear.action.VOICE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <!-- v1.24.1: One-tap vehicle-recovery dispatch -->
        <activity android:name="ae.servia.wear.RecoveryActivity"
                  android:exported="true"
                  android:label="SOS Recovery"
                  android:theme="@android:style/Theme.DeviceDefault.Light.NoActionBar">
            <intent-filter>
                <action android:name="ae.servia.wear.action.RECOVERY_SOS" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- ============== TILE SERVICES (v1.24.0 - 6 tiles total) ==============
             Each TileService is registered as an exported service the
             Wear OS Launcher discovers. After install, user long-presses
             the watch face → swipe to "Add tile" → all 6 Servia tiles
             appear in the picker.
        ============================================================== -->

        <!-- ⭐ FLAGSHIP TILE — voice assistant. Tap to talk: book / quote /
             recovery / wallet — all by speaking. Listed first so users
             see it at the top of the picker. -->
        <service
            android:name="ae.servia.wear.tiles.ServiaVoiceTileService"
            android:label="Servia · Tap to talk"
            android:description="@string/tile_voice_desc"
            android:icon="@mipmap/wear_ic_launcher"
            android:exported="true"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@mipmap/wear_ic_launcher" />
        </service>

        <service
            android:name="ae.servia.wear.tiles.QuickBookTileService"
            android:label="Servia · Quick book"
            android:description="@string/tile_quickbook_desc"
            android:icon="@mipmap/wear_ic_launcher"
            android:exported="true"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@mipmap/wear_ic_launcher" />
        </service>

        <service
            android:name="ae.servia.wear.tiles.NextBookingTileService"
            android:label="Servia · Next booking"
            android:description="@string/tile_nextbooking_desc"
            android:icon="@mipmap/wear_ic_launcher"
            android:exported="true"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@mipmap/wear_ic_launcher" />
        </service>

        <service
            android:name="ae.servia.wear.tiles.RecoveryTileService"
            android:label="Servia · SOS Recovery"
            android:description="@string/tile_recovery_desc"
            android:icon="@mipmap/wear_ic_launcher"
            android:exported="true"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@mipmap/wear_ic_launcher" />
        </service>

        <service
            android:name="ae.servia.wear.tiles.LoyaltyTileService"
            android:label="Servia · Loyalty tier"
            android:description="@string/tile_loyalty_desc"
            android:icon="@mipmap/wear_ic_launcher"
            android:exported="true"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@mipmap/wear_ic_launcher" />
        </service>

        <service
            android:name="ae.servia.wear.tiles.WalletTileService"
            android:label="Servia · Wallet"
            android:description="@string/tile_wallet_desc"
            android:icon="@mipmap/wear_ic_launcher"
            android:exported="true"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@mipmap/wear_ic_launcher" />
        </service>

        <service
            android:name="ae.servia.wear.tiles.DailyTipTileService"
            android:label="Servia · Daily tip"
            android:description="@string/tile_dailytip_desc"
            android:icon="@mipmap/wear_ic_launcher"
            android:exported="true"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER" />
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@mipmap/wear_ic_launcher" />
        </service>

        <!-- Wearable Listener Service for phone↔watch Data Layer sync -->
        <service
            android:name="ae.servia.wear.WearMessageListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/servia/" />
            </intent-filter>
        </service>
    </application>
</manifest>
