<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/servia_tip_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/servia_tip_bg"
    android:padding="14dp">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💡 SERVIA TIP"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textColor="#1E40AF" />
    <TextView
        android:id="@+id/servia_tip_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="6dp"
        android:text="Pre-summer AC: clean the filters every 30 days."
        android:textSize="13sp"
        android:textColor="#1E293B"
        android:lineSpacingExtra="2dp"
        android:maxLines="4"
        android:ellipsize="end" />
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Read more →"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#1E40AF" />
</LinearLayout>
