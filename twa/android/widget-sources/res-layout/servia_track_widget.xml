<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/servia_track_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/servia_widget_bg"
    android:padding="14dp">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📍 SERVIA"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textColor="#FCD34D" />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Track your bookings"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF" />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Tap for live ETA + crew status"
        android:textSize="11sp"
        android:textColor="#A7F3D0" />
    <Button
        android:id="@+id/servia_track_book_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="+ Book a service"
        android:textSize="11sp"
        android:textColor="#0F766E"
        android:textStyle="bold"
        android:background="@drawable/servia_widget_btn_light"
        android:padding="6dp" />
</LinearLayout>
