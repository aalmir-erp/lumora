<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/servia_search_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/servia_search_bg"
    android:padding="10dp">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔍"
        android:textSize="20sp"
        android:layout_marginEnd="10dp" />
    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Search Servia services, areas, FAQs…"
        android:textSize="13sp"
        android:textColor="#94A3B8"
        android:singleLine="true"
        android:ellipsize="end" />
    <TextView
        android:id="@+id/servia_search_mic"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:text="🎤"
        android:textSize="18sp"
        android:background="@drawable/servia_search_mic_bg"
        android:contentDescription="Voice search"
        android:clickable="true"
        android:focusable="true" />
</LinearLayout>
