<resources>
  

  <!--
    The "fullscreen" and "fullscreen-sticky" TWA manifest values correspond to "immersive" and "sticky-immersive"
    AndroidManifest values.
  -->
  
    <string-array name="display_override">
    
      
        <item>window-controls-overlay</item>
      
    
      
        <item>standalone</item>
      
    
      
        <item>minimal-ui</item>
      
    
    </string-array>
  

  <!--
    This variable below expresses the relationship between the app and the site,
    as documented in the TWA documentation at
    https://developers.google.com/web/updates/2017/10/using-twa#set_up_digital_asset_links_in_an_android_app
    and is injected into the AndroidManifest.xml
  -->
  <string name="assetStatements">
    [{
        \"relation\": [\"delegate_permission/common.handle_all_urls\"],
        \"target\": {
            \"namespace\": \"web\",
            \"site\": \"https://servia.ae\"
        }
    }]
    
  </string>  
    <string name="servia_quick_book_widget_desc">Servia quick-book — 4 most-used services in one tap</string>
    <string name="servia_track_widget_desc">Servia booking tracker — live ETA + crew status</string>
    <string name="servia_upcoming_widget_desc">Servia upcoming visit — next service + crew ETA</string>
    <string name="servia_whatsapp_widget_desc">Servia WhatsApp support — 1-tap chat with the team</string>
    <string name="servia_loyalty_widget_desc">Servia loyalty — your Ambassador tier + discount</string>
    <string name="servia_dailytip_widget_desc">Servia daily tip — UAE home-services know-how</string>
    <string name="servia_quote_widget_desc">Servia quick quote — 60-second AI estimate</string>
    <string name="servia_search_widget_desc">Servia search — find services, areas, FAQs (with voice)</string>
    <string name="servia_ask_widget_desc">Ask Servia — 1-tap chat to book, quote or track</string>
</resources>
