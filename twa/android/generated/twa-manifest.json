{
  "packageId": "ae.servia.app",
  "host": "servia.ae",
  "name": "Servia — UAE Home Services",
  "launcherName": "Servia",
  "display": "standalone",
  "themeColor": "#0D9488",
  "themeColorDark": "#000000",
  "navigationColor": "#000000",
  "navigationColorDark": "#000000",
  "navigationDividerColor": "#000000",
  "navigationDividerColorDark": "#000000",
  "backgroundColor": "#F8FAFC",
  "enableNotifications": true,
  "startUrl": "/?source=twa",
  "iconUrl": "http://localhost:8080/brand/servia-icon-2048x2048.png",
