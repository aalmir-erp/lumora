<?xml version="1.0" encoding="utf-8"?>
<!--
  v1.24.43 — Servia Faces (standalone watch face-only APK).

  Different applicationId (ae.servia.wear.faces) so it installs alongside
  the main Servia Wear app without conflict. Strips everything except the
  22 watch face services + a tiny launcher activity (Wear OS requires at
  least one launchable activity per package).

  Goal: A/B test whether co-packaging watch faces with non-face activities
  was hiding them from the system "Customize watch faces" picker. If this
  standalone APK shows up but the main app's faces don't, that confirms
  it.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">
    <uses-feature android:name="android.hardware.type.watch" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:label="@string/wf_app_name"
        android:icon="@mipmap/wear_ic_launcher"
        android:theme="@android:style/Theme.DeviceDefault"
        android:allowBackup="false"
        android:supportsRtl="true">

        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

        <activity
            android:name="ae.servia.wear.faces.LauncherActivity"
            android:exported="true"
            android:label="@string/wf_app_name"
            android:theme="@android:style/Theme.DeviceDefault.Light">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 22 face services injected at build time from
             tools/watchface/manifest_entries.xml -->
        
        <service
            android:name="ae.servia.wear.watchface.ServiaFace01BurjSunset"
            android:label="Servia · Burj Sunset"
            android:permission="android.permission.BIND_WALLPAPER"
            android:directBootAware="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.wallpaper.WallpaperService" />
                <category android:name="com.google.android.wearable.watchface.category.WATCH_FACE" />
            </intent-filter>
            <meta-data
                android:name="com.google.android.wearable.watchface.preview"
                android:resource="@drawable/wf_preview_p01" />
            <meta-data
                android:name="com.google.android.wearable.watchface.preview_circular"
                android:resource="@drawable/wf_preview_p01" />
            <meta-data
                android:name="android.service.wallpaper"
                android:resource="@xml/watch_face" />
            <!-- v1.24.45: WFF marker. Wear OS 5+ requires this property
                 (since Jan 2025) for the face to appear in the system
                 'Customize watch faces' picker. The actual face is
                 declared in res/raw/watchface_pNN.xml. -->
            <property
                android:name="com.google.wear.watchface.format.version"
                android:value="1" />
            <meta-data
                android:name="com.google.wear.watchface.format.RESOURCES"
                android:resource="@raw/watchface_p01" />
        </service>

