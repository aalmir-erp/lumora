# Copy to .env and fill in. Never commit the real .env.

# ---------- Meta WhatsApp Cloud API ----------
# Long-lived System User token from developers.facebook.com
META_ACCESS_TOKEN=
# Phone Number ID shown on the WhatsApp > API Setup page
META_PHONE_NUMBER_ID=
# WhatsApp Business Account ID (optional, used for richer endpoints)
META_WABA_ID=
# App Secret — used to verify the X-Hub-Signature-256 header on incoming webhooks
META_APP_SECRET=
# Verify token you also paste into the Meta webhook config UI (any random string)
META_VERIFY_TOKEN=change-me-to-a-long-random-string
# Graph API version
META_GRAPH_VERSION=v21.0

# ---------- AI provider ----------
# anthropic | openai
AI_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_MAX_TOKENS=1024

# ---------- App ----------
# Comma-separated list of phone numbers (E.164, no +) allowed to use the bot.
# Leave empty to allow everyone (production default once your number is verified).
ALLOWED_NUMBERS=

# Where to escalate when a customer asks for a human
HANDOFF_WHATSAPP=+9710000000000
HANDOFF_EMAIL=info@aalmirplastic.com

# Conversation memory: how many recent turns to keep per user
HISTORY_TURNS=12

# Optional Redis URL — if set, conversation history is persisted there instead
# of in-process memory. Recommended for multi-worker deploys.
REDIS_URL=

PORT=8000
LOG_LEVEL=info
