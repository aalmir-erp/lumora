# Most values can be set via the admin panel after deploy. The two
# essential env vars are SESSION_SECRET and ADMIN_BOOTSTRAP_TOKEN —
# without them, anyone could claim the admin account on first visit.

# ---------- Bootstrap (REQUIRED for first deploy) ----------
# Long random string. Generate one with: python -c "import secrets;print(secrets.token_urlsafe(32))"
ADMIN_BOOTSTRAP_TOKEN=
# Also long random. If unset, one is generated and persisted in the DB.
SESSION_SECRET=

# ---------- Database persistence ----------
# Mount a Railway volume at /data and set DB_PATH=/data/aalmir_bot.db
# so settings + orders survive redeploys.
DB_PATH=data/aalmir_bot.db

# ---------- Optional: env-only overrides ----------
# Anything you set here LOCKS that field on the admin Tokens page.
# Useful for production environments where you want to manage secrets
# from Railway directly. Leave empty to manage from the admin panel.

META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_WABA_ID=
META_GRAPH_VERSION=v21.0

AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_MAX_TOKENS=1024

HANDOFF_WHATSAPP=
HANDOFF_EMAIL=info@aalmirplastic.com

ALLOWED_NUMBERS=
HISTORY_TURNS=12
REDIS_URL=

PORT=8000
LOG_LEVEL=info
