+<!doctype html>
+<!--
+  v1.24.55 — Servia Admin Live PWA.
+
+  Single-file admin mini-app that:
+    · stores ADMIN_TOKEN once in localStorage (no logout, ever)
+    · polls /api/admin/live/feed every 4s for visitors + new messages
+    · subscribes to Web Push on first run → phone gets native notifications
+    · phone notifications auto-mirror to paired Wear OS / iOS watches
+    · notification reply action posts to /api/admin/live/chat/{sid}/reply
+    · in-app inline reply for when admin is actively watching the PWA
+    · sound alerts (beep on visitor, double-beep on chat)
+
+  Designed mobile-first. Renders in any browser, but on Android it's
+  installable as a PWA via Chrome's "Add to home screen" — making it feel
+  like a native app with no separate APK build needed.
+-->
+<html lang="en">
+<head>
+<meta name="robots" content="noindex,nofollow">
+<meta charset="utf-8">
+<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
+<meta name="theme-color" content="#0F172A">
+<title>Servia · Admin Live</title>
+<link rel="manifest" href="/admin-live.webmanifest">
+<link rel="icon" href="/icon-192.svg" type="image/svg+xml">
+<link rel="apple-touch-icon" href="/brand/servia-icon-512x512.png">
+<style>
+* { box-sizing: border-box; margin: 0; padding: 0; }
+html, body { height: 100%; background: #0F172A; color: #F1F5F9;
+  font: 14px/1.4 -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
+  -webkit-tap-highlight-color: transparent; }
+header { position: sticky; top: 0; z-index: 5; background: #1E293B;
+  border-bottom: 1px solid #334155; padding: 8px 12px;
+  display: flex; align-items: center; gap: 10px; }
+header .title { font-size: 14px; font-weight: 700; flex: 1; }
+header .dot { width: 8px; height: 8px; border-radius: 50%; background: #10B981;
+  box-shadow: 0 0 8px #10B981; }
+header .dot.off { background: #EF4444; box-shadow: 0 0 8px #EF4444; }
+header .stat { font-size: 11px; color: #94A3B8; }
+header button { background: transparent; color: #F1F5F9; border: 1px solid #475569;
+  border-radius: 6px; padding: 4px 8px; font-size: 11px; cursor: pointer; }
+header button.active { background: #0F766E; border-color: #14B8A6; }
+
+#login { padding: 22vh 16px 0; max-width: 360px; margin: 0 auto; text-align: center; }
+#login h1 { font-size: 22px; margin-bottom: 8px; color: #F1F5F9; }
+#login p { color: #94A3B8; font-size: 12px; margin-bottom: 18px; }
+#login input { width: 100%; padding: 12px; background: #1E293B; color: #F1F5F9;
+  border: 1px solid #334155; border-radius: 8px; font-size: 14px;
+  font-family: monospace; margin-bottom: 12px; }
+#login button { width: 100%; padding: 12px; background: #0D9488; color: #fff;
+  border: none; border-radius: 8px; font-size: 15px; font-weight: 600; cursor: pointer; }
+
+#tabs { display: flex; background: #1E293B; border-bottom: 1px solid #334155; }
