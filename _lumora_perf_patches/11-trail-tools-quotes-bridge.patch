+#chat-detail .msg.user      { background: #1E40AF; margin-right: auto;
+  border-bottom-left-radius: 4px; }
+#chat-detail .msg.assistant { background: #134E4A; margin-left: auto;
+  border-bottom-right-radius: 4px; }
+#chat-detail .msg .role { font-size: 9px; color: rgba(255,255,255,.6);
+  margin-bottom: 2px; text-transform: uppercase; }
+#chat-detail .composer { background: #1E293B; border-top: 1px solid #334155;
+  padding: 8px; display: flex; gap: 6px; align-items: flex-end; }
+#chat-detail .composer textarea { flex: 1; min-height: 38px; max-height: 120px;
+  padding: 8px 10px; background: #0F172A; color: #F1F5F9; border: 1px solid #334155;
+  border-radius: 8px; font: inherit; resize: none; }
+#chat-detail .composer button { padding: 9px 14px; background: #0D9488; color: #fff;
+  border: none; border-radius: 8px; font-weight: 600; cursor: pointer; font-size: 13px; }
+#chat-detail .composer button:disabled { opacity: .4; cursor: not-allowed; }
+
+.empty { text-align: center; color: #64748B; padding: 40px 16px; font-size: 13px; }
+</style>
+</head>
+<body>
+
+<!-- Login screen (shown until token is in localStorage) -->
+<div id="login">
+  <h1>Servia · Admin Live</h1>
+  <p>Paste your <code style="font-family:monospace;background:#1E293B;padding:1px 5px;border-radius:3px">ADMIN_TOKEN</code> once. Stored locally, never asked again unless you clear data.</p>
+  <input id="token-input" type="password" placeholder="Admin token" autocomplete="off">
+  <button onclick="adminLogin()">Sign in</button>
+</div>
+
+<!-- Main app (shown after login) -->
+<div id="app" style="display:none">
+  <header>
+    <div class="dot" id="status-dot"></div>
+    <div class="title">Servia Live</div>
+    <div class="stat" id="last-sync">just now</div>
+    <button id="snd-btn" onclick="toggleSound()" title="Toggle alert sound">🔔</button>
+    <button onclick="enablePush()" title="Enable phone notifications">📲</button>
+    <button onclick="logout()" title="Sign out">⏻</button>
+  </header>
+
+  <nav id="tabs">
+    <button class="active" data-tab="visitors">Visitors <span class="badge" id="vis-badge" hidden>0</span></button>
+    <button data-tab="chats">Chats <span class="badge" id="chat-badge" hidden>0</span></button>
+    <button data-tab="quotes">Quotes <span class="badge" id="quote-badge" hidden>0</span></button>
+  </nav>
+
+  <main id="content">
+    <div id="visitors-panel"></div>
+    <div id="chats-panel" hidden></div>
+    <div id="quotes-panel" hidden></div>
+  </main>
+</div>
+
+<!-- Full-screen chat detail (slides over when a chat card is tapped) -->
+<div id="chat-detail">
+  <header>
+    <button class="back" onclick="closeChat()">←</button>
+    <div class="title" id="chat-title">Chat</div>
+    <button onclick="releaseChat()" title="Hand back to bot">🤖</button>
+  </header>
+  <div class="messages" id="chat-messages"></div>
+  <div class="composer">
+    <textarea id="reply-input" placeholder="Type to reply…" rows="1"></textarea>
