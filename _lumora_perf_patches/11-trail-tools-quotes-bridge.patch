diff --git a/web/admin-live.js b/web/admin-live.js
new file mode 100644
index 0000000..a7c52d6
--- /dev/null
+++ b/web/admin-live.js
@@ -0,0 +1,420 @@
+/* v1.24.55 — Servia Admin Live PWA frontend.
+   Polls /api/admin/live/feed every 4s, updates the visitor + chat lists,
+   plays sound on new events, and on first run subscribes the browser to
+   Web Push so phone (and paired Wear OS / Apple Watch) gets native
+   notifications even when the PWA is closed.
+*/
+'use strict';
+
+const TOKEN_KEY = "servia.admin.token";
+const SOUND_KEY = "servia.admin.sound_on";
+const POLL_MS   = 4000;
+
+let token = localStorage.getItem(TOKEN_KEY) || "";
+let soundOn = (localStorage.getItem(SOUND_KEY) ?? "1") === "1";
+let pollSince = "";
+let openSid   = null;
+let seenVis   = new Set();
+let seenMsgs  = new Set();
+let visitors  = [];
+let chats     = [];
+let quotes    = [];
+
+const $ = id => document.getElementById(id);
+
+/* ----------------------------- login ----------------------------- */
+function adminLogin() {
+  const t = ($("token-input").value || "").trim();
+  if (!t) return alert("Paste the admin token");
+  // Probe — just hit a cheap admin endpoint
+  fetch("/api/admin/live/active-chats", {
+    headers: { Authorization: "Bearer " + t }
+  }).then(r => {
+    if (r.ok) {
+      localStorage.setItem(TOKEN_KEY, t);
+      token = t;
+      bootApp();
+    } else {
+      alert("Token rejected (HTTP " + r.status + "). Check ADMIN_TOKEN in Railway.");
+    }
+  }).catch(e => alert("Network error: " + e.message));
+}
+function logout() {
+  if (!confirm("Sign out and clear token?")) return;
+  localStorage.removeItem(TOKEN_KEY);
+  location.reload();
+}
+function adm(path, init = {}) {
+  init.headers = Object.assign({}, init.headers || {}, {
+    Authorization: "Bearer " + token,
+  });
+  if (init.body && typeof init.body !== "string") {
+    init.body = JSON.stringify(init.body);
+    init.headers["Content-Type"] = "application/json";
+  }
+  return fetch(path, init).then(r => r.ok ? r.json() : Promise.reject(r));
+}
+
+/* ----------------------------- boot ----------------------------- */
+function bootApp() {
+  $("login").style.display = "none";
+  $("app").style.display = "";
+  refreshSoundUi();
+  // Tabs
+  document.querySelectorAll("#tabs button").forEach(b => {
+    b.onclick = () => {
+      document.querySelectorAll("#tabs button").forEach(x => x.classList.remove("active"));
+      b.classList.add("active");
+      const t = b.dataset.tab;
+      $("visitors-panel").hidden = t !== "visitors";
+      $("chats-panel").hidden    = t !== "chats";
+      $("quotes-panel").hidden   = t !== "quotes";
+    };
+  });
+  // Service worker (for Web Push)
+  if ("serviceWorker" in navigator) {
+    navigator.serviceWorker.register("/admin-live-sw.js").catch(e =>
+      console.warn("[push] sw register failed:", e));
+  }
+  // Initial load + start polling
+  loadInitial();
+  setInterval(poll, POLL_MS);
+  // Send/back keyboard shortcut
+  $("reply-input").addEventListener("keydown", e => {
+    if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); sendReply(); }
+  });
+}
+
+async function loadInitial() {
+  try {
+    const [v, c, q] = await Promise.all([
+      adm("/api/admin/live/visitors"),
+      adm("/api/admin/live/active-chats"),
+      adm("/api/admin/quotes/recent").catch(() => ({quotes: []})),
+    ]);
+    visitors = v.visitors || [];
+    chats = c.chats || [];
+    quotes = q.quotes || [];
+    visitors.forEach(x => seenVis.add(x.visitor_id));
+    chats.forEach(x => seenMsgs.add(x.session_id + "@" + (x.last_at || "")));
+    renderVisitors(); renderChats(); renderQuotes();
+    pollSince = new Date().toISOString();
+  } catch (e) {
+    setStatus(false);
+  }
+}
+
+/* ----------------------------- polling ----------------------------- */
+async function poll() {
+  try {
+    const url = "/api/admin/live/feed?since=" + encodeURIComponent(pollSince);
+    const j = await adm(url);
+    pollSince = j.until || pollSince;
+    let newVis = false, newMsg = false;
+    (j.new_visitors || []).forEach(v => {
+      if (!seenVis.has(v.visitor_id)) {
+        seenVis.add(v.visitor_id);
+        newVis = true;
+        // Re-fetch full visitor list to get parsed UA + traffic source
+      }
+    });
+    (j.new_messages || []).forEach(m => {
+      const k = m.session_id + "@" + m.created_at;
+      if (!seenMsgs.has(k)) {
+        seenMsgs.add(k);
+        newMsg = true;
+      }
+    });
+    if (newVis || newMsg) {
+      // refresh both panels
+      const [v, c] = await Promise.all([
+        adm("/api/admin/live/visitors"),
+        adm("/api/admin/live/active-chats"),
+      ]);
+      visitors = v.visitors || [];
+      chats = c.chats || [];
+      renderVisitors(); renderChats();
+      if (newMsg)  beep("chat");
+      else if (newVis) beep("visitor");
+      // If the open chat got a new message, refresh it too
+      if (openSid && j.new_messages.find(m => m.session_id === openSid)) {
+        loadChatDetail(openSid);
+      }
+    }
+    setStatus(true);
+    $("last-sync").textContent = new Date().toLocaleTimeString();
+  } catch (e) {
+    setStatus(false);
+  }
+}
+
+function setStatus(ok) {
+  const d = $("status-dot");
+  d.classList.toggle("off", !ok);
+}
+
+/* ----------------------------- render ----------------------------- */
+function renderVisitors() {
+  const p = $("visitors-panel");
+  if (!visitors.length) { p.innerHTML = '<div class="empty">No active visitors right now.</div>'; return; }
+  p.innerHTML = visitors.map(v => {
+    const flag  = v.flag_emoji || (v.country ? "" : "");
+    const ago   = v.seconds_ago != null ? humanAgo(v.seconds_ago) : "";
+    const src   = v.traffic_source || "direct";
+    const label = v.source_label || "Direct";
+    const q     = v.search_query;
+    const chip  = `<span class="chip ${src}">${escapeHtml(label)}${q ? " · \"" + escapeHtml(q.slice(0,30)) + "\"" : ""}</span>`;
+    const ua    = (v.browser || "") + (v.os ? " · " + v.os : "");
+    return `<div class="card">
+      <div class="row">
+        <div class="head">${flag} ${escapeHtml(v.country || "??")} · ${escapeHtml(v.last_path || "/")}</div>
+        <div class="when">${ago}</div>
+      </div>
+      <div class="meta">${chip} ${escapeHtml(ua)}${v.hit_count > 1 ? " · " + v.hit_count + " hits" : ""}</div>
+    </div>`;
+  }).join("");
+  $("vis-badge").textContent = visitors.length;
+  $("vis-badge").hidden = visitors.length === 0;
+}
+
+function renderChats() {
+  const p = $("chats-panel");
+  if (!chats.length) { p.innerHTML = '<div class="empty">No active chats in the last 30 min.</div>'; return; }
+  p.innerHTML = chats.map(c => {
+    const ago = humanAgoIso(c.last_at);
+    const taken = c.taken_over ? '<span class="chip taken">AGENT</span>' : "";
+    const phone = c.phone ? "📞 " + c.phone : "Anonymous";
+    return `<div class="card" onclick="openChat('${c.session_id}')">
+      <div class="row">
+        <div class="head">${taken}${escapeHtml(phone)} · ${c.user_msg_count || 0} msgs</div>
+        <div class="when">${ago}</div>
+      </div>
+      <div class="preview">${escapeHtml(c.preview || "(no preview)")}</div>
+    </div>`;
+  }).join("");
+  const newCount = chats.filter(c => !c.taken_over).length;
+  $("chat-badge").textContent = newCount;
+  $("chat-badge").hidden = newCount === 0;
+}
+
+/* ----------------------------- chat detail ----------------------------- */
+function openChat(sid) {
+  openSid = sid;
+  $("chat-detail").classList.add("open");
+  $("chat-title").textContent = "…" + sid.slice(-8);
+  loadChatDetail(sid);
+}
+function closeChat() {
+  openSid = null;
+  $("chat-detail").classList.remove("open");
+}
+async function loadChatDetail(sid) {
+  try {
+    const j = await adm("/api/admin/live/chat/" + encodeURIComponent(sid));
+    const box = $("chat-messages");
+    box.innerHTML = (j.messages || []).map(m => {
+      const tools = (m.tool_calls || []).map(t =>
+        `<div style="background:#1e3a8a33;border-left:2px solid #60A5FA;padding:4px 6px;margin-top:4px;font-size:10px;color:#BFDBFE;border-radius:0 4px 4px 0">
+           <b>🛠 ${escapeHtml(t.name)}</b>${t.result_summary ? " · " + escapeHtml(t.result_summary) : ""}
+         </div>`).join("");
+      return `<div class="msg ${m.role}">
+         <div class="role">${m.role}${m.model_used ? " · " + escapeHtml(m.model_used) : ""}</div>
+         ${escapeHtml(m.content || "").replace(/\n/g,"<br>")}
+         ${tools}
+       </div>`;
+    }).join("");
+    box.scrollTop = box.scrollHeight;
+  } catch (e) { console.error(e); }
+}
+
+// v1.24.56 — Quotes panel: list, status update, photo upload
+function renderQuotes() {
+  const p = $("quotes-panel");
+  if (!quotes.length) {
+    p.innerHTML = '<div class="empty">No quotes in the last 7 days.</div>';
+    $("quote-badge").hidden = true;
+    return;
+  }
+  p.innerHTML = quotes.map(q => `
+    <div class="card" onclick="openQuote('${q.quote_id}')">
+      <div class="row">
+        <div class="head">${escapeHtml(q.customer_name||'?')} · <span class="chip ${(q.status||'pending')}">${escapeHtml((q.status||'pending').toUpperCase())}</span></div>
+        <div class="when">${q.created_at ? humanAgoIso(q.created_at) : ''}</div>
+      </div>
+      <div class="meta">${escapeHtml(q.quote_id)} · AED ${q.total_aed} · ${q.items_count||0} svcs · ${escapeHtml(q.phone||'?')}</div>
+      <div class="preview">${escapeHtml(q.target_date||'')} ${escapeHtml(q.time_slot||'')} · ${escapeHtml(q.address||'')}</div>
+    </div>`).join("");
+  $("quote-badge").textContent = quotes.length;
+  $("quote-badge").hidden = quotes.length === 0;
+}
+
+window.openQuote = async function(qid) {
+  // Modal-ish detail with status update + upload buttons
+  let body;
+  try {
+    const j = await adm("/api/admin/quote/" + encodeURIComponent(qid) + "/all");
+    body = j.quote;
+  } catch (e) { alert("Could not load: " + e); return; }
+  const html = `
+    <header>
+      <button class="back" onclick="closeQuoteDetail()">←</button>
+      <div class="title">${qid}</div>
+    </header>
+    <div style="overflow-y:auto;padding:14px;flex:1">
+      <h3 style="margin:0 0 6px;font-size:14px">${escapeHtml(body.customer_name||'')} · ${escapeHtml(body.phone||'')}</h3>
+      <p style="font-size:12px;color:#94A3B8;margin-bottom:10px">${escapeHtml(body.address||'')}</p>
+      <p style="font-size:12px;color:#94A3B8;margin-bottom:10px">${escapeHtml(body.target_date||'')} · ${escapeHtml(body.time_slot||'')}</p>
+      <p style="font-size:14px;color:#FCD34D;margin:8px 0"><b>AED ${body.total_aed}</b> · status: <b>${body.status||'pending'}</b></p>
+      <h4 style="margin:12px 0 4px;font-size:12px;color:#94A3B8">SERVICES</h4>
+      ${(body.items||[]).map((it,i) => `<div style="background:#1E293B;padding:6px 10px;border-radius:6px;margin:3px 0;font-size:12px">${i+1}. ${escapeHtml(it.label)} — AED ${it.price_aed}</div>`).join("")}
+      <h4 style="margin:14px 0 4px;font-size:12px;color:#94A3B8">UPDATE STATUS</h4>
+      <div style="display:flex;flex-wrap:wrap;gap:6px">
+        ${["dispatched","arrived","in_progress","done","cancelled"].map(s =>
+          `<button onclick="setQuoteStatus('${qid}','${s}')" style="padding:7px 11px;background:#0F766E;color:#fff;border:none;border-radius:6px;font-size:11px;cursor:pointer">${s.replace('_',' ')}</button>`).join("")}
+      </div>
+      <h4 style="margin:14px 0 4px;font-size:12px;color:#94A3B8">UPLOAD PHOTO / VIDEO</h4>
+      <input type="file" id="qup-file" accept="image/*,video/*" style="background:#1E293B;color:#fff;padding:6px;border-radius:6px;border:1px solid #334155">
+      <button onclick="uploadQuotePhoto('${qid}')" style="display:block;margin-top:6px;padding:8px 12px;background:#0D9488;color:#fff;border:none;border-radius:6px;cursor:pointer;font-size:12px">📤 Upload</button>
+      <h4 style="margin:14px 0 4px;font-size:12px;color:#94A3B8">QUICK LINKS</h4>
+      <div style="display:flex;gap:6px;flex-wrap:wrap">
+        <a href="/q/${qid}" target="_blank" style="padding:7px 11px;background:#1E40AF;color:#fff;border-radius:6px;text-decoration:none;font-size:11px">Customer view</a>
+        <a href="/i/${qid}" target="_blank" style="padding:7px 11px;background:#1E40AF;color:#fff;border-radius:6px;text-decoration:none;font-size:11px">Invoice</a>
+        <a href="/i/${qid}.pdf" target="_blank" style="padding:7px 11px;background:#F59E0B;color:#fff;border-radius:6px;text-decoration:none;font-size:11px">📄 PDF</a>
+      </div>
+    </div>`;
+  let det = $("quote-detail");
+  if (!det) {
+    det = document.createElement("div");
+    det.id = "quote-detail";
+    det.style.cssText = "position:fixed;inset:0;background:#0F172A;z-index:11;display:flex;flex-direction:column";
+    document.body.appendChild(det);
+  }
+  det.innerHTML = html;
+  det.style.display = "flex";
+};
+window.closeQuoteDetail = function() {
+  const d = $("quote-detail"); if (d) d.style.display = "none";
+};
+window.setQuoteStatus = async function(qid, status) {
+  await adm("/api/admin/quote/" + encodeURIComponent(qid) + "/status",
+            { method: "POST", body: { status }});
+  alert("Status set: " + status);
+  openQuote(qid); // refresh
+};
+window.uploadQuotePhoto = async function(qid) {
+  const f = $("qup-file").files[0];
+  if (!f) return alert("Pick a file first");
+  const dataUrl = await readDataUrl(f);
+  await adm("/api/admin/quote/" + encodeURIComponent(qid) + "/upload",
+            { method: "POST", body: { data_url: dataUrl, mime: f.type, kind: "vendor" }});
+  alert("Uploaded ✓");
+};
+function readDataUrl(f) {
+  return new Promise((res, rej) => {
+    const r = new FileReader();
+    r.onload = () => res(r.result); r.onerror = rej;
+    r.readAsDataURL(f);
+  });
+}
+async function sendReply() {
+  const text = $("reply-input").value.trim();
+  if (!text || !openSid) return;
+  $("reply-btn").disabled = true;
+  try {
+    await adm("/api/admin/live/chat/" + encodeURIComponent(openSid) + "/reply",
+              { method: "POST", body: { text } });
+    $("reply-input").value = "";
+    loadChatDetail(openSid);
+  } catch (e) {
+    alert("Reply failed");
+  } finally {
+    $("reply-btn").disabled = false;
+  }
+}
+async function releaseChat() {
+  if (!openSid) return;
+  if (!confirm("Hand this chat back to the bot?")) return;
+  await adm("/api/admin/live/chat/" + encodeURIComponent(openSid) + "/release",
+            { method: "POST" });
+  closeChat();
+}
+
+/* ----------------------------- sound + push ----------------------------- */
+let audioCtx;
+function beep(kind) {
+  if (!soundOn) return;
+  try {
+    audioCtx = audioCtx || new (window.AudioContext || window.webkitAudioContext)();
+    const t = audioCtx.currentTime;
+    function tone(freq, dur, delay = 0) {
+      const o = audioCtx.createOscillator();
+      const g = audioCtx.createGain();
+      o.type = "sine"; o.frequency.value = freq;
+      g.gain.setValueAtTime(0, t + delay);
+      g.gain.linearRampToValueAtTime(0.18, t + delay + 0.01);
+      g.gain.linearRampToValueAtTime(0, t + delay + dur);
+      o.connect(g); g.connect(audioCtx.destination);
+      o.start(t + delay); o.stop(t + delay + dur + 0.05);
+    }
+    if (kind === "chat")    { tone(880, 0.15); tone(1320, 0.15, 0.18); }
+    else /* visitor */      { tone(660, 0.12); }
+  } catch (_) {}
+}
+function toggleSound() {
+  soundOn = !soundOn;
+  localStorage.setItem(SOUND_KEY, soundOn ? "1" : "0");
