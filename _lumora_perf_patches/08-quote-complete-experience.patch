+</div>
+
+<script>
+const QID = "{quote_id}";
+let token = localStorage.getItem("q.token." + QID) || "";
+let lineState = {{}};   // {{ idx: {{ approved: bool, comment: str }} }}
+
+async function verify() {{
+  const phone = document.getElementById("phone").value.replace(/[^\\d]/g,"");
+  const r = await fetch("/api/q/" + QID + "/verify", {{
+    method: "POST", headers: {{"Content-Type":"application/json"}},
+    body: JSON.stringify({{phone}})
+  }});
+  const j = await r.json();
+  if (!j.ok) {{ document.getElementById("msg").textContent = "Phone doesn't match. Try again."; return; }}
+  token = j.token;
+  localStorage.setItem("q.token." + QID, token);
+  showCart();
+}}
+
+async function showCart() {{
+  const r = await fetch("/api/q/" + QID, {{ headers: {{"X-Quote-Token": token}} }});
+  const j = await r.json();
+  if (!j.ok) {{ token=""; localStorage.removeItem("q.token." + QID); return; }}
+  document.getElementById("gate").style.display="none";
+  document.getElementById("cart").style.display="block";
+  lineState = j.line_status || {{}};
+  renderLines(j.items || []);
+  document.getElementById("sub").textContent   = "AED " + j.subtotal_aed;
+  document.getElementById("vat").textContent   = "AED " + j.vat_aed;
+  document.getElementById("total").textContent = "AED " + j.total_aed;
+  document.getElementById("date").textContent  = (j.target_date||"") + " · " + (j.time_slot||"");
+  document.getElementById("addr").textContent  = j.address||"";
+  document.getElementById("status-line").innerHTML = "Status: <b>" + (j.status||"pending") + "</b>";
+  if ((j.history||[]).length) {{
+    document.getElementById("timeline").style.display="block";
+    document.getElementById("tl-events").innerHTML = j.history.map(h =>
+      `<div class="ev"><b>${{escapeHtml(h.event)}}</b> · ${{shortAt(h.at)}} · <i>${{escapeHtml(h.actor||"")}}</i>${{h.note?" — "+escapeHtml(h.note):""}}</div>`).join("");
+  }}
+  renderPhotos(j.photos || []);
+  initSig();
+}}
+
+function renderLines(items) {{
+  document.getElementById("lines").innerHTML = items.map((it, i) => {{
+    const st = lineState[i] || {{}};
+    const cls = st.approved === true ? "approved" : st.approved === false ? "rejected" : "";
+    const cmt = st.comment || "";
+    return `<div class="line ${{cls}}" id="line-${{i}}">
+      <div class="head">
+        <div>${{i+1}}. ${{escapeHtml(it.label)}}</div>
+        <div class="price">AED ${{it.price_aed}}</div>
+      </div>
+      <div class="detail">${{escapeHtml(it.detail||"")}}</div>
+      <div class="actions">
+        <button class="ok" onclick="setLine(${{i}}, true)">${{st.approved===true?"✓ Approved":"Approve"}}</button>
+        <button class="no" onclick="setLine(${{i}}, false)">${{st.approved===false?"✕ Rejected":"Reject"}}</button>
+      </div>
+      <textarea placeholder="Comment for this service…" oninput="setComment(${{i}}, this.value)" rows="1">${{escapeHtml(cmt)}}</textarea>
+    </div>`;
+  }}).join("");
+}}
+
+function setLine(i, approved) {{
+  lineState[i] = lineState[i] || {{}};
+  lineState[i].approved = approved;
+  const ln = document.getElementById("line-"+i);
+  ln.classList.remove("approved","rejected");
+  if (approved === true) ln.classList.add("approved");
+  if (approved === false) ln.classList.add("rejected");
+  ln.querySelector(".actions .ok").textContent = approved ? "✓ Approved" : "Approve";
+  ln.querySelector(".actions .no").textContent = approved===false ? "✕ Rejected" : "Reject";
+}}
+function setComment(i, v) {{
+  lineState[i] = lineState[i] || {{}};
+  lineState[i].comment = v;
+}}
