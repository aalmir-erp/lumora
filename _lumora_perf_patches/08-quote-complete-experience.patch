+.line .head{{display:flex;justify-content:space-between;font-weight:600}}
+.line .price{{color:#FCD34D}}
+.line .detail{{font-size:12px;color:#94A3B8;margin-top:2px}}
+.line .actions{{display:flex;gap:6px;margin-top:6px}}
+.line .actions button{{flex:1;padding:5px;background:#334155;color:#F1F5F9;
+border:none;border-radius:5px;font-size:11px;cursor:pointer}}
+.line .actions button.ok{{background:#0D9488}}
+.line .actions button.no{{background:#7F1D1D}}
+.line textarea{{width:100%;background:#0F172A;border:1px solid #334155;
+color:#F1F5F9;border-radius:5px;padding:6px;margin-top:5px;font:inherit;font-size:12px}}
+.line .photos{{display:flex;gap:4px;margin-top:6px;flex-wrap:wrap}}
+.line .photos img{{width:60px;height:60px;object-fit:cover;border-radius:4px;
+cursor:pointer;border:1px solid #475569}}
+.totals{{padding:10px 12px;background:#1E293B;border-radius:8px;margin:10px 0}}
+.totals .row{{display:flex;justify-content:space-between;padding:3px 0}}
+.totals .row.t{{font-size:17px;font-weight:700;color:#14B8A6;border-top:1px solid #334155;padding-top:8px;margin-top:4px}}
+.feature{{font-size:12px;color:#94A3B8;background:#1E293B;border-left:3px solid #14B8A6;
+padding:8px 12px;margin:8px 0;border-radius:0 6px 6px 0}}
+canvas{{background:#fff;border-radius:8px;width:100%;height:130px;display:block;margin:6px 0}}
+.btn{{padding:11px 14px;background:#0D9488;color:#fff;border:none;border-radius:8px;
+font-weight:600;cursor:pointer;width:100%;margin:6px 0;font-size:14px}}
+.btn.alt{{background:#1E293B;color:#F1F5F9;border:1px solid #475569}}
+.timeline{{padding:8px 12px;background:#1E293B;border-radius:8px;margin:10px 0}}
+.timeline .ev{{padding:4px 0;border-bottom:1px dashed #334155;font-size:12px}}
+.timeline .ev:last-child{{border:none}}
+.timeline .ev b{{color:#14B8A6}}
+.lightbox{{position:fixed;inset:0;background:rgba(0,0,0,.9);display:none;
+align-items:center;justify-content:center;z-index:99}}
+.lightbox.open{{display:flex}}
+.lightbox img,.lightbox video{{max-width:96vw;max-height:90vh}}
+.lightbox .close{{position:absolute;top:12px;right:14px;background:#fff;color:#000;
+border:none;border-radius:50%;width:32px;height:32px;font-size:18px;cursor:pointer}}
+input[type=text],textarea{{font:inherit}}
+</style></head><body>
+
+<div class="gate" id="gate">
+  <h2>Servia Quote</h2>
+  <p style="color:#94A3B8;font-size:12.5px;margin:8px 0">Quote <code>{quote_id}</code><br>
+  Enter the phone number used to request this quote.</p>
+  <input id="phone" type="tel" placeholder="0559396459" autocomplete="tel">
+  <button class="btn" onclick="verify()">View quote</button>
+  <p id="msg" style="color:#FCA5A5;font-size:12px;margin-top:8px"></p>
+</div>
+
+<div class="cart container" id="cart">
+  <h2>Quote <code>{quote_id}</code></h2>
+  <div id="lines"></div>
+  <div class="totals">
+    <div class="row"><div>Subtotal</div><div id="sub">—</div></div>
+    <div class="row"><div>VAT 5%</div><div id="vat">—</div></div>
+    <div class="row t"><div>Total</div><div id="total">—</div></div>
+  </div>
+  <div class="feature">📅 <span id="date"></span> · 📍 <span id="addr"></span></div>
+  <div class="feature" id="status-line">Status: <b>pending</b></div>
+  <div class="timeline" id="timeline" style="display:none"><b>Status timeline</b><div id="tl-events"></div></div>
+
+  <h3 style="margin:14px 0 6px;font-size:13px">📸 Service photos</h3>
+  <div id="photos" class="photos" style="display:flex;gap:6px;flex-wrap:wrap;margin-bottom:6px;min-height:50px"></div>
+  <input type="file" id="up-input" accept="image/*,video/*" style="display:none" onchange="onPhotoSelect(event)">
+  <button class="btn alt" onclick="document.getElementById('up-input').click()">📤 Upload photo / video</button>
+
+  <h3 style="margin:14px 0 6px;font-size:13px">✍️ Your signature</h3>
+  <canvas id="sig" width="500" height="130"></canvas>
+  <button class="btn alt" onclick="clearSig()">Clear signature</button>
