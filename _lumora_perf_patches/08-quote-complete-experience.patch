+"""Multi-service quote signing + payment + status + photos (v1.24.56).
+
+End-to-end customer + vendor + admin experience around a single quote.
+
+PUBLIC ROUTES:
+  GET  /q/{id}                 customer signing page (phone-gated)
+  POST /api/q/{id}/verify      → token
+  GET  /api/q/{id}             → full quote data (includes line statuses + photos)
+  POST /api/q/{id}/sign        signature + per-line approvals + customer notes
+  POST /api/q/{id}/upload      customer uploads a photo (compressed)
+  GET  /p/{id}                 payment page (Stripe / WA fallback)
+  POST /api/p/{id}/checkout    create Stripe Checkout session (returns hosted url)
+  GET  /i/{id}                 print-friendly invoice page
+
+ADMIN ROUTES (require ADMIN_TOKEN):
+  POST /api/admin/quote/{id}/status     update quote-level status
+  POST /api/admin/quote/{id}/line-status  update per-line status
+  POST /api/admin/quote/{id}/upload     vendor/Servia uploads service photo/video
+  GET  /api/admin/quote/{id}/all        full data + signature + photos for admin
+
+Tables added at first call (idempotent):
+  multi_quotes              (added: status, line_status_json, paid_at, paid_amount)
+  quote_photos              new — base64-stored compressed images, kind='before|during|after|invoice'
+  quote_status_history      new — timeline events
+"""
+from __future__ import annotations
+import base64 as _b64
+import datetime as _dt
+import hashlib
+import hmac
+import json as _json
+import os
+from typing import Any
+
+from fastapi import APIRouter, Depends, HTTPException, Request
+from fastapi.responses import HTMLResponse
+from pydantic import BaseModel
+
+from . import db
+from .auth import require_admin
+from .config import get_settings
+
+
+public_router = APIRouter(tags=["quote-public"])
+admin_router  = APIRouter(prefix="/api/admin/quote", tags=["quote-admin"],
+                          dependencies=[Depends(require_admin)])
+
+
+def _now() -> str:
+    return _dt.datetime.utcnow().isoformat() + "Z"
+
+
+def _ensure_schema() -> None:
+    with db.connect() as c:
+        # Additive columns on multi_quotes (no-op if already there)
+        for ddl in (
+            "ALTER TABLE multi_quotes ADD COLUMN status TEXT DEFAULT 'pending'",
+            "ALTER TABLE multi_quotes ADD COLUMN line_status_json TEXT",
+            "ALTER TABLE multi_quotes ADD COLUMN paid_amount REAL",
+            "ALTER TABLE multi_quotes ADD COLUMN stripe_session_id TEXT",
+        ):
+            try: c.execute(ddl)
+            except Exception: pass
+        c.execute("""CREATE TABLE IF NOT EXISTS quote_photos (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            quote_id TEXT, line_index INTEGER,
+            kind TEXT,           -- before|during|after|invoice|customer
+            uploaded_by TEXT,    -- customer|vendor|admin
+            data_url TEXT,       -- base64 inline (compressed client-side)
+            mime TEXT, bytes INTEGER, caption TEXT,
+            created_at TEXT)""")
+        c.execute("""CREATE TABLE IF NOT EXISTS quote_status_history (
+            id INTEGER PRIMARY KEY AUTOINCREMENT,
+            quote_id TEXT, event TEXT, actor TEXT, note TEXT, at TEXT)""")
+
+
+def _quote(quote_id: str) -> dict | None:
+    _ensure_schema()
+    with db.connect() as c:
+        try:
+            r = c.execute("SELECT * FROM multi_quotes WHERE quote_id=?",
+                          (quote_id,)).fetchone()
+        except Exception: return None
+    if not r: return None
+    d = dict(r)
+    try: d["items"] = _json.loads(d.get("items_json") or "[]")
+    except Exception: d["items"] = []
+    try: d["line_status"] = _json.loads(d.get("line_status_json") or "{}")
+    except Exception: d["line_status"] = {}
+    return d
+
+
+def _photos(quote_id: str) -> list[dict]:
+    with db.connect() as c:
+        rows = c.execute(
+            "SELECT id, line_index, kind, uploaded_by, mime, bytes, caption, "
+            "created_at FROM quote_photos WHERE quote_id=? ORDER BY id DESC",
+            (quote_id,)).fetchall()
+    return [dict(r) for r in rows]
+
+
+def _history(quote_id: str) -> list[dict]:
+    with db.connect() as c:
+        rows = c.execute(
+            "SELECT event, actor, note, at FROM quote_status_history "
+            "WHERE quote_id=? ORDER BY id DESC LIMIT 50",
+            (quote_id,)).fetchall()
+    return [dict(r) for r in rows]
+
+
+def _add_event(quote_id: str, event: str, actor: str, note: str = "") -> None:
+    with db.connect() as c:
+        c.execute(
+            "INSERT INTO quote_status_history(quote_id, event, actor, note, at) "
+            "VALUES(?,?,?,?,?)", (quote_id, event, actor, note, _now()))
+
+
+def _sign_token(quote_id: str, phone: str) -> str:
+    s = get_settings()
+    secret = (getattr(s, "ADMIN_TOKEN", "") or os.getenv("ADMIN_TOKEN", "lumora-token")).encode()
+    msg = f"{quote_id}|{phone}".encode()
+    return hmac.new(secret, msg, hashlib.sha256).hexdigest()[:32]
+
+
+def _verify_token(token: str, quote_id: str, phone: str) -> bool:
+    return hmac.compare_digest(token or "", _sign_token(quote_id, phone))
+
+
+# ---------------------------------------------------------------------------
+@public_router.get("/q/{quote_id}", response_class=HTMLResponse)
+def quote_landing(quote_id: str) -> str:
+    q = _quote(quote_id)
+    if not q:
+        return HTMLResponse("<h1>Quote not found</h1>", status_code=404)
+    return _render_quote_html(quote_id, q)
+
+
+def _render_quote_html(quote_id: str, q: dict) -> str:
+    return f"""<!doctype html><html><head><meta charset="utf-8">
+<meta name="viewport" content="width=device-width,initial-scale=1">
+<title>Servia · Quote {quote_id}</title>
+<style>
