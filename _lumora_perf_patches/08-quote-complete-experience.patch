+@public_router.post("/api/q/{quote_id}/sign")
+def sign(quote_id: str, body: _SignBody, request: Request) -> dict:
+    q = _quote(quote_id)
+    if not q: raise HTTPException(404)
+    tok = request.headers.get("X-Quote-Token", "")
+    stored = "".join(ch for ch in (q.get("phone") or "") if ch.isdigit())
+    if not _verify_token(tok, quote_id, stored):
+        return {"ok": False, "error": "invalid token"}
+    line_status = body.line_status or {}
+    with db.connect() as c:
+        c.execute(
+            "UPDATE multi_quotes SET signed_at=?, signature_data_url=?, "
+            "line_status_json=?, status='signed', "
+            "notes=COALESCE(notes,'') || ? WHERE quote_id=?",
+            (_now(), body.signature_data_url[:200000],
+             _json.dumps(line_status),
+             ("\n--- customer note ---\n" + (body.customer_note or "")) if body.customer_note else "",
+             quote_id))
+    _add_event(quote_id, "signed", q.get("phone") or "customer",
+               f"signed {len([k for k,v in line_status.items() if v.get('approved')])} of {len(q.get('items',[]))} services")
+    db.log_event("quote", quote_id, "customer_signed",
+                 actor=q.get("phone") or "?",
+                 details={"approved_count":
+                          len([k for k,v in line_status.items() if v.get("approved")]),
+                          "total": q.get("total_aed")})
+    try:
+        from . import admin_alerts as _aa
+        approved_lines = [it["label"] for i, it in enumerate(q.get("items",[]))
+                          if line_status.get(str(i), {}).get("approved") is True
+                          or line_status.get(i, {}).get("approved") is True]
+        rejected_lines = [it["label"] for i, it in enumerate(q.get("items",[]))
+                          if line_status.get(str(i), {}).get("approved") is False
+                          or line_status.get(i, {}).get("approved") is False]
+        _aa.notify_admin(
+            f"✅ Customer signed quote {quote_id}\n"
+            f"{q.get('customer_name','?')} · {q.get('phone','?')}\n"
+            f"Total: AED {q.get('total_aed')}\n"
+            f"Approved: {', '.join(approved_lines) or 'all'}\n"
+            + (f"Rejected: {', '.join(rejected_lines)}\n" if rejected_lines else "") +
+            f"Schedule: {q.get('target_date')} {q.get('time_slot')}",
+            kind="quote_signed", urgency="normal", meta={"quote_id": quote_id})
+    except Exception: pass
+    return {"ok": True, "quote_id": quote_id, "signed_at": _now(),
+            "total_aed": q.get("total_aed")}
