+.lightbox .close{{position:absolute;top:12px;right:14px;background:#fff;color:#000;
+border:none;border-radius:50%;width:32px;height:32px;font-size:18px;cursor:pointer}}
+input[type=text],textarea{{font:inherit}}
+</style></head><body>
+
+<div class="gate" id="gate">
+  <h2>Servia Quote</h2>
+  <p style="color:#94A3B8;font-size:12.5px;margin:8px 0">Quote <code>{quote_id}</code><br>
