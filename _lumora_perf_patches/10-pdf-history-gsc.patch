+  const j = await r.json();
+  if (j.ok) {{
+    document.body.innerHTML = `<div style="text-align:center;padding:18vh 16px;font-family:system-ui;color:#F1F5F9;background:#0F172A;min-height:100vh">
+      <h1 style="color:#10B981">✅ Approved!</h1>
+      <p style="color:#94A3B8;margin:10px 0 16px">Quote <code>${{QID}}</code> is signed.<br>Our team is being dispatched.</p>
+      <p><a style="display:inline-block;padding:11px 18px;background:#0D9488;color:#fff;border-radius:8px;text-decoration:none;margin:4px" href="/p/${{QID}}">💳 Pay AED ${{j.total_aed||""}}</a></p>
+      <p><a style="display:inline-block;padding:11px 18px;background:#1E293B;color:#F1F5F9;border-radius:8px;text-decoration:none;margin:4px" href="/i/${{QID}}">📄 View invoice</a></p>
+      <p style="font-size:12px;color:#64748B;margin-top:14px">Or WhatsApp +971 56 4020087</p>
+    </div>`;
+  }} else alert("Could not sign: " + (j.error||"server error"));
+}}
+
+function escapeHtml(s){{return String(s||"").replace(/[&<>"']/g, c=>({{"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}}[c]))}}
+function shortAt(iso){{ try {{ return new Date(iso).toLocaleString("en-GB", {{ hour:"2-digit", minute:"2-digit", day:"2-digit", month:"short" }}); }} catch(_) {{ return iso||""; }} }}
+
+if (token) showCart();
+</script>
+</body></html>"""
