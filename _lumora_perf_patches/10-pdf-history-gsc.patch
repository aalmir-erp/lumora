+                f"line_items[{i}][price_data][product_data][name]", it["label"]))
+            line_items_data.append((
+                f"line_items[{i}][price_data][unit_amount]", str(int(round(it["price_aed"] * 100)))))
+            line_items_data.append((
+                f"line_items[{i}][quantity]", "1"))
+        line_items_data.append(("mode", "payment"))
+        line_items_data.append(("success_url", f"https://{domain}/i/{quote_id}?paid=1"))
+        line_items_data.append(("cancel_url", f"https://{domain}/p/{quote_id}"))
+        line_items_data.append(("metadata[quote_id]", quote_id))
+        body = urllib.parse.urlencode(line_items_data).encode()
+        req = urllib.request.Request(
+            "https://api.stripe.com/v1/checkout/sessions",
+            data=body,
+            headers={"Authorization": f"Bearer {sk}",
+                     "Content-Type": "application/x-www-form-urlencoded"})
+        with urllib.request.urlopen(req, timeout=10) as r:
+            session = _json.loads(r.read())
+        with db.connect() as c:
+            c.execute("UPDATE multi_quotes SET stripe_session_id=? WHERE quote_id=?",
+                      (session.get("id"), quote_id))
+        _add_event(quote_id, "checkout_started", "customer", "stripe")
+        return {"ok": True, "url": session.get("url"), "session_id": session.get("id")}
+    except Exception as e:
+        return {"ok": False, "error": f"stripe: {e}"}
+
+
+# ---------------------------------------------------------------------------
+@public_router.get("/i/{quote_id}", response_class=HTMLResponse)
+def invoice_view(quote_id: str) -> str:
+    q = _quote(quote_id)
+    if not q: return HTMLResponse("<h1>Invoice not found</h1>", status_code=404)
+    items_html = "".join(
+        f"<tr><td>{i+1}</td><td><b>{it['label']}</b><br><small>{it.get('detail','')}</small></td>"
+        f"<td style='text-align:right'>AED {it['price_aed']}</td></tr>"
+        for i, it in enumerate(q.get("items") or []))
+    paid = bool(q.get("paid_at"))
+    return f"""<!doctype html><html><head><meta charset="utf-8">
+<meta name="viewport" content="width=device-width,initial-scale=1">
+<title>Servia Invoice {quote_id}</title>
+<style>
+body{{font:14px/1.5 system-ui;background:#fff;color:#111;padding:20px;max-width:720px;margin:0 auto}}
+.head{{display:flex;justify-content:space-between;align-items:flex-start;border-bottom:2px solid #0D9488;padding-bottom:14px;margin-bottom:18px}}
+.head .brand{{font-size:24px;font-weight:700;color:#0D9488}}
+.head .meta{{text-align:right;font-size:12.5px;color:#64748B}}
+table{{width:100%;border-collapse:collapse;margin:12px 0}}
+table th{{background:#F1F5F9;text-align:left;padding:8px;font-size:12px;font-weight:600}}
+table td{{padding:8px;border-bottom:1px solid #E2E8F0;font-size:13px;vertical-align:top}}
+.totals{{margin-top:14px;float:right;width:300px}}
+.totals .row{{display:flex;justify-content:space-between;padding:4px 0;font-size:13px}}
+.totals .row.total{{font-size:17px;font-weight:700;border-top:2px solid #0D9488;padding-top:8px;margin-top:6px;color:#0D9488}}
+.stamp{{display:inline-block;border:2px solid {'#10B981' if paid else '#DC2626'};color:{'#10B981' if paid else '#DC2626'};font-weight:700;
+padding:4px 12px;border-radius:6px;transform:rotate(-3deg);font-size:13px;margin-top:14px}}
+.btn{{display:inline-block;padding:9px 14px;background:#0D9488;color:#fff;border-radius:6px;
+font-size:13px;text-decoration:none;margin:8px 4px}}
+.note{{font-size:11px;color:#64748B;border-top:1px solid #E2E8F0;padding-top:10px;margin-top:24px;clear:both}}
+@media print {{ body{{padding:0}} .no-print{{display:none}} }}
+</style></head><body>
+<div class="head">
+  <div>
+    <div class="brand">Servia</div>
+    <div style="font-size:11px;color:#64748B">UAE home services platform</div>
+    <div style="font-size:11px;color:#64748B">Operated by Urban Services</div>
+  </div>
+  <div class="meta">
+    <div><b>INVOICE</b></div>
+    <div>Quote: <code>{quote_id}</code></div>
+    <div>Date: {(q.get('created_at') or '')[:10]}</div>
+  </div>
+</div>
+<div style="margin-bottom:14px;font-size:12.5px">
+  <b>Bill to:</b><br>
+  {q.get('customer_name','')}<br>
+  {q.get('phone','')}<br>
+  {q.get('address','')}
+</div>
+<table>
+  <thead><tr><th>#</th><th>Service</th><th style="text-align:right">Amount</th></tr></thead>
+  <tbody>{items_html}</tbody>
+</table>
+<div class="totals">
+  <div class="row"><div>Subtotal</div><div>AED {q.get('subtotal_aed')}</div></div>
+  <div class="row"><div>VAT 5%</div><div>AED {q.get('vat_aed')}</div></div>
+  <div class="row total"><div>Total</div><div>AED {q.get('total_aed')}</div></div>
+</div>
+<div style="clear:both"></div>
+<div class="stamp">{'✓ PAID' if paid else 'PAYMENT PENDING'}</div>
+{'<div style="font-size:11px;color:#64748B;margin-top:6px">Paid on: ' + q.get('paid_at','') + '</div>' if paid else ''}
+<div class="no-print" style="margin-top:24px;text-align:center">
+  <a class="btn" href="javascript:window.print()">🖨️ Print / Save as PDF</a>
+  <a class="btn" href="/q/{quote_id}">↩ Back to quote</a>
+  {'<a class="btn" href="/p/' + quote_id + '">💳 Pay now</a>' if not paid else ''}
+</div>
+<div class="note">
+  This is a digitally generated invoice based on customer-signed quote {quote_id}.
+  Customer signed digitally on {q.get('signed_at','—')}.
+  Real-time service status, photos, comments and invoice updates are available 24/7
+  at <b>servia.ae/q/{quote_id}</b> with phone-gated access. Service photos and
+  videos are uploaded by both vendor team and customer in compressed format
+  inside the quote page.
+</div>
+</body></html>"""
+
+
+# ---------------------------------------------------------------------------
+# ADMIN endpoints — require ADMIN_TOKEN
+class _StatusBody(BaseModel):
+    status: str   # signed|dispatched|arrived|in_progress|done|cancelled|paid
+    note: str | None = ""
+
+@admin_router.post("/{quote_id}/status")
+def admin_set_status(quote_id: str, body: _StatusBody) -> dict:
+    q = _quote(quote_id)
+    if not q: raise HTTPException(404)
+    with db.connect() as c:
+        c.execute("UPDATE multi_quotes SET status=? WHERE quote_id=?",
+                  (body.status, quote_id))
+    _add_event(quote_id, body.status, "admin", body.note or "")
+    # Notify customer via existing push pipeline (silent if no push subs)
+    try:
+        from . import push_notifications as _pn
+        _pn.send_to_phone(q.get("phone"),
+                          title=f"Servia · {body.status.replace('_',' ').title()}",
+                          body=f"Quote {quote_id} status updated.",
+                          url=f"/q/{quote_id}", kind="quote_status")
+    except Exception: pass
+    return {"ok": True, "quote_id": quote_id, "status": body.status}
+
+
+class _LineStatusBody(BaseModel):
+    line_index: int
+    status: str    # done|cancelled|in_progress
+    note: str | None = ""
+
+@admin_router.post("/{quote_id}/line-status")
+def admin_set_line_status(quote_id: str, body: _LineStatusBody) -> dict:
+    q = _quote(quote_id)
+    if not q: raise HTTPException(404)
+    line_status = q.get("line_status") or {}
+    line_status[str(body.line_index)] = {
+        **(line_status.get(str(body.line_index)) or {}),
+        "vendor_status": body.status,
+        "vendor_note": body.note,
+        "updated_at": _now(),
+    }
+    with db.connect() as c:
+        c.execute("UPDATE multi_quotes SET line_status_json=? WHERE quote_id=?",
+                  (_json.dumps(line_status), quote_id))
+    _add_event(quote_id, f"line[{body.line_index}]:{body.status}", "admin", body.note or "")
+    return {"ok": True, "line_index": body.line_index, "status": body.status}
+
+
+@admin_router.post("/{quote_id}/upload")
+def admin_upload(quote_id: str, body: _UploadBody) -> dict:
+    if not _quote(quote_id): raise HTTPException(404)
+    return _save_photo(quote_id, body, "vendor")
+
+
+@admin_router.get("/{quote_id}/all")
+def admin_full(quote_id: str) -> dict:
+    q = _quote(quote_id)
+    if not q: raise HTTPException(404)
+    return {
+        "quote": q,
+        "history": _history(quote_id),
+        "photos": _photos(quote_id),
+    }
+
+
+# ---------------------------------------------------------------------------
+# Real PDF generation via fpdf2 (pure Python, no system deps).
+# Returns a downloadable PDF of the invoice. Falls back to HTML 'print to PDF'
+# button if fpdf2 isn't installed (graceful degrade).
+@public_router.get("/i/{quote_id}.pdf")
+def invoice_pdf(quote_id: str):
+    q = _quote(quote_id)
+    if not q:
+        raise HTTPException(404, "quote not found")
+    try:
+        from fpdf import FPDF
+    except Exception:
+        # Library missing — redirect to the HTML print page
+        from fastapi.responses import RedirectResponse
+        return RedirectResponse(url=f"/i/{quote_id}", status_code=302)
+
+    pdf = FPDF(format="A4", unit="mm")
+    pdf.set_auto_page_break(auto=True, margin=15)
+    pdf.add_page()
+    # Header band
+    pdf.set_fill_color(13, 148, 136)
+    pdf.rect(0, 0, 210, 28, "F")
+    pdf.set_text_color(255, 255, 255)
+    pdf.set_font("Helvetica", "B", 22)
+    pdf.set_xy(15, 8)
+    pdf.cell(0, 8, "Servia", ln=1)
+    pdf.set_font("Helvetica", "", 9)
+    pdf.set_xy(15, 18)
+    pdf.cell(0, 4, "UAE home services platform", ln=1)
+    pdf.set_xy(150, 8)
+    pdf.set_font("Helvetica", "B", 14)
+    pdf.cell(45, 6, "INVOICE", align="R", ln=1)
+    pdf.set_font("Helvetica", "", 9)
+    pdf.set_xy(150, 16)
+    pdf.cell(45, 4, f"Quote: {quote_id}", align="R", ln=1)
+    pdf.set_xy(150, 21)
+    pdf.cell(45, 4, f"Date: {(q.get('created_at') or '')[:10]}", align="R", ln=1)
+
+    # Bill-to box
+    pdf.set_text_color(15, 23, 42)
+    pdf.set_xy(15, 38)
+    pdf.set_font("Helvetica", "B", 10)
+    pdf.cell(0, 5, "Bill to:", ln=1)
+    pdf.set_font("Helvetica", "", 10)
+    pdf.set_x(15)
+    pdf.cell(0, 5, _safe(q.get("customer_name") or ""), ln=1)
+    pdf.set_x(15)
+    pdf.cell(0, 5, _safe(q.get("phone") or ""), ln=1)
+    pdf.set_x(15)
+    pdf.multi_cell(120, 5, _safe(q.get("address") or ""))
+
+    # Items table
+    y0 = pdf.get_y() + 6
+    pdf.set_y(y0)
+    pdf.set_fill_color(241, 245, 249)
+    pdf.set_text_color(15, 23, 42)
+    pdf.set_font("Helvetica", "B", 9)
+    pdf.cell(10, 7, "#", border=1, fill=True, align="C")
+    pdf.cell(120, 7, "Service", border=1, fill=True)
+    pdf.cell(60, 7, "Amount (AED)", border=1, fill=True, align="R", ln=1)
+    pdf.set_font("Helvetica", "", 10)
+    items = q.get("items") or []
+    for i, it in enumerate(items):
+        pdf.cell(10, 7, str(i + 1), border=1, align="C")
+        pdf.cell(120, 7, _safe(it.get("label", ""))[:60], border=1)
+        pdf.cell(60, 7, f"{it.get('price_aed', 0):,.2f}", border=1, align="R", ln=1)
+        if it.get("detail"):
+            pdf.set_font("Helvetica", "I", 8)
+            pdf.set_text_color(100, 116, 139)
+            pdf.cell(10, 5, "", border="LR")
+            pdf.cell(180, 5, _safe(it["detail"])[:90], border="LR", ln=1)
+            pdf.set_text_color(15, 23, 42)
+            pdf.set_font("Helvetica", "", 10)
+
+    # Totals
+    pdf.ln(4)
+    sub = q.get("subtotal_aed") or 0
+    vat = q.get("vat_aed") or 0
+    tot = q.get("total_aed") or 0
+    pdf.set_x(115)
+    pdf.cell(45, 6, "Subtotal", align="R")
+    pdf.cell(35, 6, f"AED {sub:,.2f}", align="R", ln=1)
+    pdf.set_x(115)
+    pdf.cell(45, 6, "VAT 5%", align="R")
+    pdf.cell(35, 6, f"AED {vat:,.2f}", align="R", ln=1)
+    pdf.set_font("Helvetica", "B", 12)
+    pdf.set_text_color(13, 148, 136)
+    pdf.set_x(115)
+    pdf.cell(45, 8, "Total", align="R")
+    pdf.cell(35, 8, f"AED {tot:,.2f}", align="R", ln=1)
+
+    # Stamp
+    pdf.ln(8)
+    pdf.set_font("Helvetica", "B", 11)
+    paid = bool(q.get("paid_at"))
+    if paid:
+        pdf.set_text_color(16, 185, 129)
+        pdf.cell(0, 8, "PAID  +  " + (q.get("paid_at") or "")[:19], ln=1)
+    else:
+        pdf.set_text_color(220, 38, 38)
+        pdf.cell(0, 8, "PAYMENT PENDING", ln=1)
+
+    # Footer note
+    pdf.ln(8)
+    pdf.set_text_color(100, 116, 139)
+    pdf.set_font("Helvetica", "", 8)
+    pdf.multi_cell(0, 4,
+        f"Digitally generated invoice based on customer-signed quote {quote_id}. "
+        f"Customer signed digitally on {q.get('signed_at') or '—'}. "
+        f"Real-time service status, photos, comments, and invoice updates are "
+        f"available 24/7 at servia.ae/q/{quote_id} with phone-gated access. "
+        f"Service photos and videos are uploaded by both vendor team and "
+        f"customer in compressed format inside the quote page.")
+
+    out = pdf.output(dest="S")
+    if isinstance(out, str): out = out.encode("latin-1")
+    from fastapi.responses import Response
+    return Response(content=bytes(out), media_type="application/pdf",
+                    headers={"Content-Disposition":
+                             f'attachment; filename="invoice-{quote_id}.pdf"'})
+
+
+def _safe(s: str) -> str:
+    """fpdf2 default font is Latin-1 only. Strip non-ASCII to avoid crashes."""
+    try:
+        return (s or "").encode("latin-1", "replace").decode("latin-1")
+    except Exception:
+        return (s or "").encode("ascii", "ignore").decode("ascii")
+
+
+# ---------------------------------------------------------------------------
+# Stripe webhook hook — call from /api/webhooks/stripe in main.py to mark
+# quote paid + add event. Pure helper, no router.
+def mark_paid(quote_id: str, amount_aed: float | None = None) -> None:
+    q = _quote(quote_id)
+    if not q: return
+    with db.connect() as c:
+        c.execute("UPDATE multi_quotes SET paid_at=?, paid_amount=?, status='paid' WHERE quote_id=?",
+                  (_now(), amount_aed, quote_id))
+    _add_event(quote_id, "paid", "stripe", f"AED {amount_aed}" if amount_aed else "")
+    try:
+        from . import admin_alerts as _aa
+        _aa.notify_admin(
+            f"💰 Payment received for {quote_id}\n"
+            f"Amount: AED {amount_aed or q.get('total_aed')}\n"
+            f"{q.get('customer_name','?')} · {q.get('phone','?')}",
+            kind="payment_received", urgency="normal",
+            meta={"quote_id": quote_id})
+    except Exception: pass
