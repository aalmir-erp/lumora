+.chip.search { background: #1E40AF; color: #DBEAFE; }
+.chip.social { background: #831843; color: #FCE7F3; }
+.chip.direct { background: #334155; color: #CBD5E1; }
+.chip.taken { background: #B45309; color: #FEF3C7; }
+
