+/* --- photo upload with client-side compression --- */
+async function onPhotoSelect(e) {{
+  const f = e.target.files[0];
+  if (!f) return;
+  let dataUrl;
+  if (f.type.startsWith("image/")) {{
+    dataUrl = await compressImage(f, 1200, 0.72);
+  }} else {{
+    dataUrl = await readAsDataUrl(f);
+    if (f.size > 6 * 1024 * 1024) {{
+      if (!confirm("Video is "+ (f.size/1024/1024).toFixed(1)+" MB — upload anyway?")) return;
+    }}
+  }}
+  const caption = prompt("Add a caption (optional):") || "";
+  const r = await fetch("/api/q/" + QID + "/upload", {{
+    method:"POST", headers:{{"Content-Type":"application/json","X-Quote-Token":token}},
+    body: JSON.stringify({{ data_url: dataUrl, mime: f.type, caption }})
+  }});
+  const j = await r.json();
+  if (j.ok) {{ alert("Uploaded ✓"); showCart(); }}
+  else alert("Upload failed: " + (j.error||""));
+}}
+function readAsDataUrl(f) {{
+  return new Promise((res, rej) => {{
+    const r = new FileReader();
+    r.onload = () => res(r.result);
+    r.onerror = rej;
+    r.readAsDataURL(f);
+  }});
+}}
+function compressImage(f, maxDim, quality) {{
+  return new Promise((res, rej) => {{
+    const r = new FileReader();
+    r.onload = () => {{
+      const img = new Image();
+      img.onload = () => {{
+        const canvas = document.createElement("canvas");
+        const ratio = Math.min(maxDim / img.width, maxDim / img.height, 1);
+        canvas.width = Math.round(img.width * ratio);
+        canvas.height = Math.round(img.height * ratio);
+        const ctx = canvas.getContext("2d");
+        ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
+        res(canvas.toDataURL("image/jpeg", quality));
+      }};
+      img.onerror = rej;
+      img.src = r.result;
+    }};
+    r.onerror = rej;
+    r.readAsDataURL(f);
+  }});
+}}
+
+/* --- signature pad --- */
+let sigCtx, drawing=false;
+function initSig() {{
+  const c = document.getElementById("sig");
+  sigCtx = c.getContext("2d");
+  sigCtx.lineWidth = 2; sigCtx.lineCap="round"; sigCtx.strokeStyle="#0F172A";
+  function pos(e){{const r=c.getBoundingClientRect();const t=e.touches?e.touches[0]:e;return {{x:(t.clientX-r.left)*c.width/r.width,y:(t.clientY-r.top)*c.height/r.height}}}}
+  function down(e){{e.preventDefault();drawing=true;const p=pos(e);sigCtx.beginPath();sigCtx.moveTo(p.x,p.y)}}
+  function move(e){{if(!drawing)return;e.preventDefault();const p=pos(e);sigCtx.lineTo(p.x,p.y);sigCtx.stroke()}}
+  function up(){{drawing=false}}
+  c.addEventListener("mousedown",down);c.addEventListener("mousemove",move);
+  c.addEventListener("mouseup",up);c.addEventListener("mouseleave",up);
+  c.addEventListener("touchstart",down,{{passive:false}});
+  c.addEventListener("touchmove",move,{{passive:false}});
+  c.addEventListener("touchend",up);
+}}
+function clearSig() {{ const c=document.getElementById("sig");c.getContext("2d").clearRect(0,0,c.width,c.height); }}
+
+async function approve() {{
