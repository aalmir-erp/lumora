+    q = _quote(quote_id)
+    if not q: raise HTTPException(404)
+    stored = "".join(ch for ch in (q.get("phone") or "") if ch.isdigit())
+    if not _verify_token(t, quote_id, stored):
+        raise HTTPException(403, "invalid token")
+    with db.connect() as c:
+        r = c.execute("SELECT data_url, mime FROM quote_photos WHERE id=? AND quote_id=?",
+                      (pid, quote_id)).fetchone()
+    if not r: raise HTTPException(404)
+    # Decode and stream — tiny payload since base64 is small after compression
+    data_url, mime = r["data_url"], (r["mime"] or "image/jpeg")
+    if "," in data_url:
+        b64 = data_url.split(",", 1)[1]
+    else:
+        b64 = data_url
+    raw = _b64.b64decode(b64)
+    from fastapi.responses import Response
+    return Response(content=raw, media_type=mime,
+                    headers={"Cache-Control": "public, max-age=3600"})
