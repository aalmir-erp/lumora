+def _save_photo(quote_id: str, body: _UploadBody, uploaded_by: str) -> dict:
+    data = body.data_url or ""
+    if not data.startswith("data:"):
+        return {"ok": False, "error": "expected data URL"}
+    sz = len(data) * 3 // 4
+    if sz > 12 * 1024 * 1024:  # 12 MB cap (after client compression)
+        return {"ok": False, "error": "too large (max 12 MB after compression)"}
+    with db.connect() as c:
+        c.execute(
+            "INSERT INTO quote_photos(quote_id, line_index, kind, uploaded_by, "
+            "data_url, mime, bytes, caption, created_at) "
+            "VALUES(?,?,?,?,?,?,?,?,?)",
+            (quote_id, body.line_index, body.kind or "customer", uploaded_by,
+             data, body.mime, sz, body.caption, _now()))
+        pid = c.lastrowid
+    _add_event(quote_id, "photo_uploaded", uploaded_by,
+               f"{body.kind or 'photo'}{' · ' + body.caption if body.caption else ''}")
+    return {"ok": True, "photo_id": pid, "bytes": sz}
